PORT=5000

# JWT secret for signing tokens (set a long random string)
JWT_SECRET=

# MongoDB connection string (Atlas or local)
# Example (Atlas SRV):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-hostname>/<dbName>?retryWrites=true&w=majority&appName=<appName>
MONGO_URI=

# Optional: only needed if you hit `querySrv ECONNREFUSED` with `mongodb+srv://...`
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8

# Optional: set to true in production to exit if DB can't connect
DB_FAIL_FAST=false
